{
  "expo": {
    "name": "MeatManager",
    "slug": "meatmanager",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "meatbig",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kmeatmaster.meatmanager",
      "buildNumber": "1",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLName": "com.kmeatmaster.meatmanager.oauth",
            "CFBundleURLSchemes": ["meatbig"]
          }
        ],
        "LSApplicationQueriesSchemes": ["kakaokompassauth", "kakaolink"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.kmeatmaster.meatmanager",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "meatbig",
              "host": "auth-callback"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "서류 사진을 촬영하거나 갤러리에서 선택합니다.",
          "cameraPermission": "서류를 촬영하여 AI로 자동 인식합니다."
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "축산물 이력번호 바코드 스캔을 위해 카메라 접근 권한이 필요합니다.",
          "enableCodeScanner": true
        }
      ],
      "expo-notifications",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "05a0fe1c-65ec-464e-a161-5c14fe31d3e2"
      }
    },
    "owner": "jbaek777",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/05a0fe1c-65ec-464e-a161-5c14fe31d3e2"
    }
  }
}
